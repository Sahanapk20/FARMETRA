// Type definitions
export type TranslationKey = keyof typeof translations.chatbot.en | keyof typeof translations.quickActions.en | keyof typeof translations.common.en | keyof typeof translations.landing.en | keyof typeof translations.navigation.en | keyof typeof translations.auth.en;

// Helper function to get translation
export const getTranslation = (section: keyof typeof translations, key: string, language: string): string => {
  const sectionData = translations[section] as any;
  const langSection = sectionData[language] || sectionData.en;
  return langSection[key] || key;
};
